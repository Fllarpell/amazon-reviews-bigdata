POSTGRES_PASSWORD=postgres
POSTGRES_HOST_AUTH_METHOD=trust
POSTGRES_PORT=5432

# Full Hugging Face files for Appliances: ~1.1 GiB combined (reviews ~930 MiB). Omit JSONL_LINE_LIMIT (or use: make pipeline-full).
# FORCE_RAW_REDOWNLOAD=1
# HTTP_TIMEOUT_SEC=900

APP_DB_USER=pipeline_app
APP_DB_NAME=review_analytics

PGUSER=pipeline_app
PGDATABASE=review_analytics

PGHOST=127.0.0.1
PGPORT=5432

# Local Docker dev (relative path under HDFS user hadoop): project/warehouse
# University cluster (example): /user/team0/project/warehouse
HDFS_WAREHOUSE_BASE=project/warehouse
# Optional: lower replication on shared HDFS to save space (course policy permitting), e.g. 2
# HDFS_REPLICATION=2
# Sqoop + HDFS from Docker (see Makefile hadoop-up, pipeline-all): USE_DOCKER_HADOOP=1
# USE_DOCKER_HADOOP=1
# Skip copying data/staging/*.csv into HDFS after Sqoop:
# SKIP_HDFS_STAGING=1
# If Sqoop container cannot reach Postgres on Linux, set host IP:
# SQOOP_PG_HOST=192.168.1.10

POSTGRES_CONTAINER_NAME=review_pipeline_postgres
